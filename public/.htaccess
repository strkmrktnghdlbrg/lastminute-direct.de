# Auto-generated 301 redirects: legacy WP URLs -> new Astro structure
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Article archives -> cluster hubs
  RewriteRule ^stadtreisen/?$ /staedtereisen/ [R=301,L]
  RewriteRule ^abenteurer/?$ /reisearten/ [R=301,L]
  RewriteRule ^familie/?$ /reisearten/ [R=301,L]
  RewriteRule ^feinschmecker/?$ /reisearten/ [R=301,L]
  RewriteRule ^tipps-und-tricks/?$ /ratgeber/ [R=301,L]
  RewriteRule ^reisetipps-fuer-anfaenger/?$ /ratgeber/ [R=301,L]

  # Articles -> /magazin/<slug>/
  RewriteRule ^stadtreisen/nachhaltige-staedtereisen/?$ /magazin/nachhaltige-staedtereisen/ [R=301,L]
  RewriteRule ^stadtreisen/budgetfreundliche-staedtereisen/?$ /magazin/budgetfreundliche-staedtereisen/ [R=301,L]
