---
import BaseLayout from '../layouts/BaseLayout.astro';
import DealCard from '../components/DealCard.astro';
import ClusterCard from '../components/ClusterCard.astro';
import DestinationCard from '../components/DestinationCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { DEALS, FEATURED_DEAL, DESTINATIONS } from '../data/deals';
import { unsplash } from '../data/images';
import { getCollection } from 'astro:content';

const articles = await getCollection('artikel');
const featured = articles
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0))
  .slice(0, 3);

const clusterCards = [
  { href: '/reiseziele/', title: 'Strand & Inseln', text: 'Von Karibik bis Kreta: die schönsten Strände, Inseln und Resorts für deine Auszeit am Meer.', tags: ['Karibik', 'Asien', 'Europa', 'Luxus-Resorts'], icon: 'M3 20l9-16 9 16M7 20h10' },
  { href: '/staedtereisen/', title: 'Städtereisen', text: 'Kultur, Shopping und Nachtleben: viele Guides zu Europas spannendsten Metropolen.', tags: ['Wochenende', 'Kulinarik', 'Street-Art', 'mit Kindern'], icon: 'M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01' },
  { href: '/reisearten/', title: 'Familie & Solo', text: 'Passende Reisen für jede Konstellation, von Familienstränden bis zu Trips für Alleinreisende.', tags: ['Familie', 'Senioren', 'Alleinreisende', 'Hundestrände'], icon: 'M12 8a4 4 0 100-8 4 4 0 000 8zM4 21c0-4 4-6 8-6s8 2 8 6' },
  { href: '/reisearten/', title: 'Abenteuer & Aktiv', text: 'Wassersport, Strandspiele und Aktivurlaub für alle, die im Urlaub nicht stillsitzen können.', tags: ['Wassersport', 'Beachvolleyball', 'Aktivurlaub'], icon: 'M12 2l3 6 6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1z' },
  { href: '/reisearten/', title: 'Genuss & Romantik', text: 'Strandrestaurants, Wellness-Retreats und romantische Auszeiten für Feinschmecker und Paare.', tags: ['Feinschmecker', 'Wellness', 'Romantik'], icon: 'M5 3v18M5 8h6a4 4 0 010 8H5M16 3c2 2 3 4 3 7s-1 5-3 7' },
  { href: '/ratgeber/', title: 'Reise-Ratgeber', text: 'Last-Minute-Buchungstipps, Packlisten und Sicherheit. Alles für die clevere spontane Reise.', tags: ['Last-Minute-Tipps', 'Packlisten', 'Sicherheit'], icon: 'M9 11l3 3 8-8M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11' },
];
---
<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-inner">
      <span class="eyebrow"><span class="dot"></span> Kurzurlaube · Last Minute · Einfach los</span>
      <h1>Spontan weg. Jetzt fliegen.</h1>
      <p class="lead">Die besten Last-Minute-Schnäppchen für Strand, Stadt und Sonne. Ohne langes Suchen, direkt zum nächsten Abenteuer.</p>

      <form class="searchbar" action="/suche/" method="get">
        <div class="field">
          <label for="q">Reiseziel</label>
          <input id="q" name="q" type="text" placeholder="Wohin solls gehen?" />
        </div>
        <div class="field">
          <label for="art">Reiseart</label>
          <select id="art" name="art">
            <option>Strandurlaub</option>
            <option>Städtereise</option>
            <option>All-Inclusive</option>
            <option>Familienurlaub</option>
          </select>
        </div>
        <div class="field">
          <label for="zeit">Wann</label>
          <select id="zeit" name="zeit">
            <option>Diese Woche</option>
            <option>Nächste Woche</option>
            <option>Flexibel</option>
          </select>
        </div>
        <button type="submit" class="go">Deals finden</button>
      </form>

      <div class="trust-row">
        <span>✓ Über 60 Reise-Ratgeber</span>
        <span>✓ Geprüfte Last-Minute-Angebote</span>
        <span>✓ Kostenloser Deal-Alarm</span>
      </div>

      <div class="hero-card-row">
        <div class="hero-card">
          <span class="badge">Deal der Woche</span>
          <h3>{FEATURED_DEAL.destination}</h3>
          <p>Direktflug ab Frankfurt, {FEATURED_DEAL.stars}-Sterne-Strandhotel, nur noch wenige Plätze für diese Woche.</p>
          <div class="price"><b>ab {FEATURED_DEAL.priceFrom} €</b> <small>{FEATURED_DEAL.priceNote}</small></div>
        </div>
        <div class="hero-photo" style={`background-image: linear-gradient(180deg, rgba(14,22,32,0) 30%, rgba(14,22,32,.55) 100%), url('${unsplash(FEATURED_DEAL.imageId, 900)}')`}></div>
      </div>
    </div>
  </section>

  <!-- DEALS -->
  <section class="section wrap" id="deals">
    <div class="section-head">
      <div>
        <h2>Last-Minute Deals der Woche</h2>
        <p>Handverlesene Schnäppchen, die sich diese Woche besonders lohnen.</p>
      </div>
      <a href="/deals/" class="link-arrow">Alle Deals ansehen →</a>
    </div>
    <div class="grid-4">
      {DEALS.map((deal) => <DealCard deal={deal} />)}
    </div>
  </section>

  <!-- CLUSTERS -->
  <section class="section wrap">
    <div class="section-head">
      <div>
        <h2>Finde deine Reise nach Typ</h2>
        <p>Egal ob mit Familie, allein oder zu zweit, hier startet deine Inspiration.</p>
      </div>
    </div>
    <div class="grid-3">
      {clusterCards.map((c) => <ClusterCard {...c} />)}
    </div>
  </section>

  <!-- DESTINATIONS -->
  <section class="section dest-section">
    <div class="wrap">
      <div class="section-head">
        <div>
          <h2 style="color:var(--color-cloud-whisper)">Beliebte Reiseziele</h2>
          <p style="color:rgba(245,244,223,.7)">Die Ziele, nach denen unsere Leser diese Woche am häufigsten suchen.</p>
        </div>
        <a href="/reiseziele/" class="link-arrow light">Alle Ziele →</a>
      </div>
      <div class="dest-grid">
        {DESTINATIONS.map((dest) => <DestinationCard dest={dest} />)}
      </div>
    </div>
  </section>

  <!-- MAGAZINE -->
  {featured.length > 0 && (
    <section class="section wrap">
      <div class="section-head">
        <div>
          <h2>Aus dem Reise-Magazin</h2>
          <p>Tipps, Inspiration und Entscheidungshilfen für deinen nächsten Kurzurlaub.</p>
        </div>
        <a href="/magazin/" class="link-arrow">Zum Magazin →</a>
      </div>
      <div class="grid-3">
        {featured.map((a) => (
          <ArticleCard
            slug={a.id}
            title={a.data.title}
            description={a.data.description}
            heroTheme={a.data.heroTheme}
            clusters={a.data.clusters}
            readingTime={a.data.readingTime}
          />
        ))}
      </div>
    </section>
  )}

  <Newsletter />
</BaseLayout>

<style>
  .hero { background: var(--color-skybound-blue); color: var(--color-cloud-whisper); position: relative; overflow: hidden; padding: 64px 0 0; }
  .hero::after { content: ""; position: absolute; right: -160px; top: -120px; width: 520px; height: 520px; border-radius: 50%; background: var(--color-cosmic-violet); opacity: .35; filter: blur(8px); }
  .hero-inner { position: relative; z-index: 2; }
  .hero h1 { font-size: clamp(48px, 8vw, 80px); max-width: 14ch; }
  .hero .lead { font-size: 20px; font-weight: 400; opacity: .92; max-width: 48ch; margin-top: 24px; line-height: 1.4; }
  .eyebrow { margin-bottom: 20px; opacity: .9; }

  .searchbar { margin-top: 40px; display: flex; flex-wrap: wrap; border: 1.5px solid var(--color-cloud-whisper); border-radius: var(--radius-pill); max-width: 820px; overflow: hidden; }
  .searchbar .field { flex: 1 1 180px; padding: 16px 24px; border-right: 1px solid rgba(245,244,223,.3); }
  .searchbar .field label { display: block; font-size: 12px; opacity: .7; margin-bottom: 2px; }
  .searchbar .field input, .searchbar .field select { background: transparent; border: 0; color: var(--color-cloud-whisper); font-family: var(--font-text); font-size: 15px; font-weight: 500; width: 100%; outline: none; }
  .searchbar .field select option { color: var(--color-midnight-ink); }
  .searchbar .field input::placeholder { color: rgba(245,244,223,.6); }
  .searchbar .go { background: var(--color-sunset-orange); color: var(--color-cloud-whisper); border: 0; padding: 0 36px; font-family: var(--font-display); font-weight: 550; font-size: 16px; cursor: pointer; }
  .searchbar .go:hover { filter: brightness(1.08); }
  .trust-row { margin-top: 22px; display: flex; gap: 28px; flex-wrap: wrap; font-size: 13px; opacity: .85; }

  .hero-card-row { margin-top: 72px; display: grid; grid-template-columns: 1.3fr 1fr; gap: 0; align-items: end; }
  .hero-card { background: var(--color-horizon-blue); border-radius: 160px 160px 0 0; padding: 48px; box-shadow: var(--shadow-card); }
  .hero-card .badge { display: inline-block; background: var(--color-sunset-orange); color: var(--color-cloud-whisper); font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: var(--radius-pill); text-transform: uppercase; letter-spacing: .03em; margin-bottom: 16px; }
  .hero-card h3 { font-size: 28px; margin-bottom: 10px; }
  .hero-card p { font-size: 15px; opacity: .9; margin-bottom: 24px; }
  .hero-card .price b { font-size: 40px; font-family: var(--font-display); }
  .hero-card .price small { font-size: 14px; opacity: .75; }
  .hero-photo { height: 340px; border-radius: 16px 16px 0 0; background-size: cover; background-position: center; margin-left: -40px; box-shadow: var(--shadow-card); }

  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .dest-section { background: var(--color-midnight-ink); }
  .dest-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .link-arrow.light { color: var(--color-pale-peach); border-color: var(--color-pale-peach); }

  @media (max-width: 980px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
    .dest-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-card-row { grid-template-columns: 1fr; }
    .hero-photo { margin-left: 0; margin-top: 20px; }
  }
  @media (max-width: 640px) {
    .grid-4, .grid-3, .dest-grid { grid-template-columns: 1fr; }
    .searchbar { flex-direction: column; border-radius: 24px; }
    .searchbar .field { border-right: 0; border-bottom: 1px solid rgba(245,244,223,.3); }
    .searchbar .go { padding: 18px; }
  }
</style>
