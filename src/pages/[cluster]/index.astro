---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import { CLUSTERS } from '../../data/clusters';
import { unsplash, IMAGE_POOL } from '../../data/images';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('artikel');
  return CLUSTERS.map((cluster) => ({
    params: { cluster: cluster.slug },
    props: {
      cluster,
      articles: all.filter((a) => a.data.clusters.includes(cluster.key)),
    },
  }));
}

const { cluster, articles } = Astro.props;
const heroImg = (IMAGE_POOL[cluster.heroTheme] ?? IMAGE_POOL.strand)[0];
const sorted = articles.sort((a, b) => a.data.title.localeCompare(b.data.title, 'de'));
---
<BaseLayout title={cluster.title} description={cluster.short}>
  <section class="hub-hero">
    <div class="wrap">
      <nav class="crumbs"><a href="/">Start</a> <span>/</span> {cluster.title}</nav>
      <h1>{cluster.title}</h1>
      <p>{cluster.intro}</p>
      <span class="count">{articles.length} Artikel</span>
    </div>
  </section>

  <section class="section wrap">
    {sorted.length > 0 ? (
      <div class="grid-3">
        {sorted.map((a) => (
          <ArticleCard
            slug={a.id}
            title={a.data.title}
            description={a.data.description}
            heroTheme={a.data.heroTheme}
            clusters={a.data.clusters}
            readingTime={a.data.readingTime}
          />
        ))}
      </div>
    ) : (
      <p class="empty">Hier entstehen gerade neue Inhalte. Schau bald wieder vorbei oder stöbere im <a href="/magazin/">Magazin</a>.</p>
    )}
  </section>

  <Newsletter />
</BaseLayout>

<style>
  .hub-hero { background: var(--color-skybound-blue); color: var(--color-cloud-whisper); padding: 64px 0 56px; }
  .crumbs { font-size: 13px; opacity: .8; margin-bottom: 20px; }
  .crumbs a { text-decoration: underline; }
  .crumbs span { margin: 0 6px; }
  .hub-hero h1 { font-size: clamp(40px, 6vw, 64px); max-width: 16ch; }
  .hub-hero p { font-size: 18px; opacity: .92; max-width: 56ch; margin-top: 20px; line-height: 1.45; }
  .count { display: inline-block; margin-top: 24px; font-size: 13px; background: rgba(245,244,223,.15); padding: 6px 14px; border-radius: var(--radius-pill); }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .empty { font-size: 18px; color: #45525f; }
  .empty a { color: var(--color-skybound-blue); text-decoration: underline; }
  @media (max-width: 980px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-3 { grid-template-columns: 1fr; } }
</style>
