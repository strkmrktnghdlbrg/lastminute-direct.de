---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CLUSTERS } from '../../data/clusters';

const allArticles = await getCollection('artikel');
const total = allArticles.length;

// Build per-cluster groups (sorted alphabetically within each cluster)
const clusterGroups = CLUSTERS.map((cluster) => ({
  cluster,
  articles: allArticles
    .filter((a) => a.data.clusters.includes(cluster.key))
    .sort((a, b) => a.data.title.localeCompare(b.data.title, 'de')),
})).filter((g) => g.articles.length > 0);
---
<BaseLayout title="Reise-Magazin" description="Alle Artikel: Reiseziele, Städtereisen, Reisearten und Ratgeber für deinen nächsten Kurzurlaub.">
  <section class="hub-hero">
    <div class="wrap">
      <nav class="crumbs"><a href="/">Start</a> <span>/</span> Magazin</nav>
      <h1>Reise-Magazin</h1>
      <p>Inspiration, Tipps und Entscheidungshilfen für spontane Kurzurlaube. {total} Artikel rund um Strand, Stadt und Sonne.</p>
    </div>
  </section>

  {clusterGroups.map(({ cluster, articles }) => (
    <section class="section wrap cluster-section">
      <div class="cluster-header">
        <h2><a href={`/${cluster.slug}/`} class="cluster-title-link">{cluster.title}</a></h2>
        <a href={`/${cluster.slug}/`} class="see-all">Alle {articles.length} ansehen &rarr;</a>
      </div>
      <div class="grid-3">
        {articles.slice(0, 6).map((a) => (
          <ArticleCard
            slug={a.id}
            title={a.data.title}
            description={a.data.description}
            heroTheme={a.data.heroTheme}
            clusters={a.data.clusters}
            readingTime={a.data.readingTime}
          />
        ))}
      </div>
      {articles.length > 6 && (
        <div class="more-link">
          <a href={`/${cluster.slug}/`} class="btn btn-secondary">Alle {articles.length} Artikel zu {cluster.title} ansehen</a>
        </div>
      )}
    </section>
  ))}
</BaseLayout>

<style>
  .hub-hero { background: var(--color-skybound-blue); color: var(--color-cloud-whisper); padding: 64px 0 56px; }
  .crumbs { font-size: 13px; opacity: .8; margin-bottom: 20px; }
  .crumbs a { text-decoration: underline; } .crumbs span { margin: 0 6px; }
  .hub-hero h1 { font-size: clamp(40px, 6vw, 64px); }
  .hub-hero p { font-size: 18px; opacity: .92; max-width: 56ch; margin-top: 20px; }
  .cluster-section { border-bottom: 1px solid rgba(171,171,156,.3); padding-bottom: 48px; }
  .cluster-section:last-child { border-bottom: none; }
  .cluster-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px; gap: 16px; flex-wrap: wrap; }
  .cluster-header h2 { font-size: 28px; margin: 0; }
  .cluster-title-link { color: inherit; text-decoration: none; }
  .cluster-title-link:hover { color: var(--color-skybound-blue); }
  .see-all { font-size: 14px; color: var(--color-skybound-blue); text-decoration: underline; white-space: nowrap; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .more-link { margin-top: 24px; text-align: center; }
  @media (max-width: 980px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-3 { grid-template-columns: 1fr; } .cluster-header { flex-direction: column; gap: 8px; } }
</style>
