---
import Logo from './Logo.astro';
import { NAV } from '../data/site';
---
<header class="nav">
  <div class="wrap nav-inner">
    <Logo />
    <nav class="links" aria-label="Hauptnavigation">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a href="/deals/" class="btn btn-ghost-light deal-cta">Deal-Alarm</a>
    <button class="nav-toggle" data-drawer-toggle aria-label="Menü öffnen">
      <svg width="26" height="26" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </div>
</header>

<div class="drawer-backdrop" id="drawer-backdrop"></div>
<aside class="drawer" id="drawer" aria-label="Mobile Navigation">
  <button class="drawer-close" data-drawer-close aria-label="Menü schließen">
    <svg width="28" height="28" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>
  {NAV.map((item) => <a href={item.href} data-drawer-close>{item.label}</a>)}
  <a href="/deals/" class="btn btn-ghost-light" style="margin-top:16px" data-drawer-close>Deal-Alarm</a>
</aside>

<style>
  .nav { position: sticky; top: 0; z-index: 50; background: var(--color-skybound-blue); color: var(--color-cloud-whisper); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 72px; }
  .links { display: flex; gap: 26px; align-items: center; }
  .links a { font-size: 15px; font-weight: 450; opacity: .92; transition: opacity .25s ease; }
  .links a:hover { opacity: 1; }
  .deal-cta { padding: 9px 18px; font-size: 14px; }
  .nav-toggle { display: none; background: none; border: 0; color: inherit; cursor: pointer; }
  @media (max-width: 900px) {
    .links, .deal-cta { display: none; }
    .nav-toggle { display: block; }
  }
</style>
