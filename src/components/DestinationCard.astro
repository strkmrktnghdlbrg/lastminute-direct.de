---
import { unsplash } from '../data/images';
import type { Destination } from '../data/deals';
interface Props { dest: Destination }
const { dest } = Astro.props;
---
<a class={`dest ${dest.tall ? 'tall' : ''}`} href="/reiseziele/">
  <img src={unsplash(dest.imageId, 700)} alt={`${dest.name} Reiseziel`} loading="lazy" />
  <div class="label"><div class="k">{dest.kind}</div><h3>{dest.name}</h3></div>
</a>
<style>
  .dest { position: relative; height: 280px; border-radius: var(--radius-card); overflow: hidden; display: flex; align-items: flex-end; padding: 24px; }
  .dest::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(14,22,32,0) 35%, rgba(14,22,32,.8) 100%); z-index: 1; }
  .dest img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
  .dest:hover img { transform: scale(1.06); }
  .dest .label { position: relative; z-index: 2; color: var(--color-cloud-whisper); }
  .dest .label .k { font-size: 12px; text-transform: uppercase; letter-spacing: .05em; color: var(--color-pale-peach); }
  .dest .label h3 { font-size: 24px; margin-top: 4px; }
  .dest.tall { grid-row: span 2; height: auto; }
  @media (max-width: 900px) { .dest.tall { grid-row: span 1; height: 280px; } }
</style>
