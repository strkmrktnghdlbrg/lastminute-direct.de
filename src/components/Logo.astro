---
interface Props { class?: string }
const { class: cls = '' } = Astro.props;
---
<a href="/" class={`logo ${cls}`} aria-label="Lastminute Direct Startseite">
  <svg viewBox="0 0 24 24" fill="none" width="26" height="26" aria-hidden="true">
    <path d="M2 16l9-3 4-9 2 1-2 8 6 2v2l-7-1-3 4-2-1 1-4-8-1z" fill="currentColor" />
  </svg>
  <span>Lastminute Direct</span>
</a>
<style>
  .logo { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 600; font-size: 20px; letter-spacing: -0.02em; }
</style>
